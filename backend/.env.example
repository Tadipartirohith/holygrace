# ─── Required ──────────────────────────────────────────────
# MongoDB connection string and database name.
MONGO_URL="mongodb://localhost:27017"
DB_NAME="grace_community_church"

# ─── Admin Access ──────────────────────────────────────────
# Long random token required to call /api/admin/* endpoints.
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_TOKEN=""

# ─── Razorpay (optional — placeholders work in mock mode) ──
RAZORPAY_KEY_ID="rzp_test_REPLACE_WITH_YOUR_KEY"
RAZORPAY_KEY_SECRET="REPLACE_WITH_YOUR_SECRET"

# ─── Resend Email (optional — emails are skipped if blank) ─
RESEND_API_KEY=""
RESEND_API_URL="https://api.resend.com/emails"
RESEND_FROM_EMAIL="Grace Community <onboarding@resend.dev>"

# ─── Where prayer-request notifications are sent ───────────
ADMIN_EMAIL="pastor@gracecommunity.org"
